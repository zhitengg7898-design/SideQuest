MONGODB_URI=mongodb+srv://DATABASE_USERNAME:DATABASE_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=sidequest_db
PORT=3000
SESSION_SECRET=replace-with-a-long-random-string

# Production (Railway + Vercel): set these on the hosts, not required for local dev
# Railway: NODE_ENV=production, CLIENT_ORIGIN=https://your-app.vercel.app
# Vercel: VITE_API_URL=https://your-api.up.railway.app
